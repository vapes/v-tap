{
  "name": "last-tap",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["server"],
  "scripts": {
    "dev": "vite",
    "dev:server": "npx tsx watch server/src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:server": "npx esbuild server/src/index.ts --bundle --platform=node --target=node20 --outfile=server/dist/index.js --format=esm --packages=external",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview",
    "start": "node server/dist/index.js",
    "rtp": "node scripts/rtp-calculator.js"
  },
  "dependencies": {
    "pixi.js": "^7.3.3"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
